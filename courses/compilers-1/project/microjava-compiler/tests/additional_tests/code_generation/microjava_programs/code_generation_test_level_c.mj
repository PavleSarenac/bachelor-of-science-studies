program MicroJavaProgram

class Class1
{
    int field1;
    bool field2;
    int field3[];
    Class1 field4[];

    {
        void class_method_1()
        {
            print('C'); print('l'); print('a'); print('s'); print('s'); print('1'); print('_');
            print('c'); print('l'); print('a'); print('s'); print('s'); print('_');
            print('m'); print('e'); print('t'); print('h'); print('o'); print('d'); print('_');
            print('1');
            print(eol);
        }

        void class_method_2()
        {
            print('C'); print('l'); print('a'); print('s'); print('s'); print('1'); print('_');
            print('c'); print('l'); print('a'); print('s'); print('s'); print('_');
            print('m'); print('e'); print('t'); print('h'); print('o'); print('d'); print('_');
            print('2');
            print(eol);
        }

        void class_method_3()
        {
            print('C'); print('l'); print('a'); print('s'); print('s'); print('1'); print('_');
            print('c'); print('l'); print('a'); print('s'); print('s'); print('_');
            print('m'); print('e'); print('t'); print('h'); print('o'); print('d'); print('_');
            print('3'); print(' '); print('s'); print('t'); print('a'); print('r'); print('t');
            print(eol);

            this.field1 = 888;
            print(this.field1);
            print(eol);

            field1 = 999;
            print(field1);
            print(eol);

            print('C'); print('l'); print('a'); print('s'); print('s'); print('1'); print('_');
            print('c'); print('l'); print('a'); print('s'); print('s'); print('_');
            print('m'); print('e'); print('t'); print('h'); print('o'); print('d'); print('_');
            print('3'); print(' '); print('e'); print('n'); print('d');
            print(eol);
        }
    }
}

