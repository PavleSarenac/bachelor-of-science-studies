interface Interface1
{
    void interface_method_1();
    void interface_method_2()
    {
        print('I'); print('n'); print('t'); print('e'); print('r'); print('f'); print('a'); print('c'); print('e'); print('1'); print('_');
        print('i'); print('n'); print('t'); print('e'); print('r'); print('f'); print('a'); print('c'); print('e'); print('_');
        print('m'); print('e'); print('t'); print('h'); print('o'); print('d'); print('_');
        print('2');
        print(eol);
    }
}

