int var1, var2;
bool var3;

{
    void testObjectInstantiation()
        Class1 obj11, obj12;
    {
        obj11 = new Class1();
        obj12 = new Class1();
    }

    void testObjectBasicFieldAccessAndAssignment()
        Class1 obj11;
    {
        obj11 = new Class1();

        obj11.field1 = 5;
        print(obj11.field1);
        print(eol);

        obj11.field2 = true;
        print(obj11.field2);
        print(eol);
        print(eol);

        // expected output:
        // 5
        // 1
    }

    void testObjectAdvancedFieldAccessAndAssignment()
        Class1 obj11;
    {
        obj11 = new Class1();

        obj11.field3 = new int[10];
        obj11.field3[7] = 15;
        print(obj11.field3[7]);
        print(eol);

        obj11.field4 = new Class1[5];
        obj11.field4[3] = new Class1();
        obj11.field4[3].field1 = 25;
        print(obj11.field4[3].field1);
        print(eol);

        obj11.field4[4] = new Class1();
        obj11.field4[4].field3 = new int[3];
        obj11.field4[4].field3[2] = 444;
        print(obj11.field4[4].field3[2]);
        print(eol);

        obj11.field4[4].field3[2]++;
        print(obj11.field4[4].field3[2]);
        print(eol);

        obj11.field4[4].field3[2]--;
        print(obj11.field4[4].field3[2]);
        print(eol);

        obj11.field1 = 200;
        obj11.field1++;
        print(obj11.field1);
        print(eol);
        print(eol);

        // expected output:
        // 15
        // 25
        // 444
        // 445
        // 444
        // 201
    }

    void testObjectMethodCalls()
        Class1 obj1;
    {
        obj1 = new Class1();
        obj1.class_method_1();
        obj1.class_method_2();
        obj1.class_method_3();

        obj1 = new Class2();
        obj1.class_method_1();
        obj1.class_method_2();
    }

    void main()
    {
        testObjectInstantiation();

        testObjectBasicFieldAccessAndAssignment();
        testObjectAdvancedFieldAccessAndAssignment();

        testObjectMethodCalls();
    }
}